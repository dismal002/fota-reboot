<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="537"
    android:versionName="5.3.7"
    coreApp="true"
    package="com.foss.fota.sysoper">
    
    <uses-sdk
        android:minSdkVersion="21"
        android:targetSdkVersion="33"/>
        
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.REBOOT"/>
    <uses-permission android:name="android.permission.ACCESS_CACHE_FILESYSTEM"/>
    <uses-permission android:name="android.permission.DELETE_CACHE_FILES"/>
    <uses-permission android:name="android.permission.RECOVERY"/>
    
    <application
        android:theme="@android:style/Theme.Black.NoTitleBar"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:name="com.foss.fota.sysoper.MyApplication"
        android:persistent="true"
        android:allowBackup="false">
        
        <service
            android:name="com.foss.fota.sysoper.SysService"
            android:enabled="true"
            android:exported="true"/>
            
        <service
            android:name="com.foss.fota.sysoper.RecoveryService"
            android:enabled="true"
            android:exported="true"/>
            
        <meta-data
            android:name="VERSION"
            android:value="OTA"/>
    </application>
</manifest>
